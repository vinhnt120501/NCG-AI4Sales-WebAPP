# MẪU secrets cho Streamlit Community Cloud.
# KHÔNG điền key thật vào file này (nó được commit lên GitHub).
# Cách dùng: vào dashboard app trên share.streamlit.io > Settings > Secrets,
# rồi DÁN nội dung bên dưới (đã thay bằng key thật) vào ô Secrets.

FPT_API_KEY = "sk-xxxxxxxxxxxxxxxx"
FPT_BASE_URL = "https://mkp-api.fptcloud.jp/v1"
FPT_MODEL = "GLM-5.1"
